# ══════════════════════════════════════════════════════════════════════════════
# DRIVES ON — Variables d'environnement
# Copier ce fichier en .env.local et remplir les valeurs.
# Ne jamais committer .env.local (contient des secrets).
# ══════════════════════════════════════════════════════════════════════════════

# ── Application ───────────────────────────────────────────────────────────────
# URL publique de l'application — OBLIGATOIRE en production.
# Utilisée dans les emails d'invitation, de reset mot de passe et de notification.
# Dev : http://localhost:3000 (valeur par défaut si absente)
# Prod : https://votre-domaine.com (sans slash final)
NEXT_PUBLIC_APP_URL=https://votre-domaine.com

# ── Supabase ──────────────────────────────────────────────────────────────────
# Récupérer sur https://app.supabase.com → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://VOTRE_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=VOTRE_ANON_KEY
# ⚠ Sensible — ne jamais exposer côté client (pas de préfixe NEXT_PUBLIC_)
SUPABASE_SERVICE_ROLE_KEY=VOTRE_SERVICE_ROLE_KEY

# ── Email — Postmark ──────────────────────────────────────────────────────────
# Récupérer sur https://account.postmarkapp.com → Servers → API Tokens
# ⚠ Sensible — ne jamais exposer côté client
POSTMARK_API_KEY=VOTRE_POSTMARK_API_KEY
# Adresse expéditeur — doit être vérifiée (Sender Signature) dans Postmark
# Le domaine doit avoir SPF + DKIM configurés
NOTIFY_FROM_EMAIL=contact@votre-domaine.com
