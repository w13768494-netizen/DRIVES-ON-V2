# Supabase — récupérer sur https://app.supabase.com → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://VOTRE_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=VOTRE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=VOTRE_SERVICE_ROLE_KEY

# URL publique de l'application (utilisée dans les emails d'invitation et de reset)
NEXT_PUBLIC_APP_URL=https://votre-domaine.com

# Postmark — récupérer sur https://account.postmarkapp.com → API Tokens
POSTMARK_API_KEY=VOTRE_POSTMARK_API_KEY
NOTIFY_FROM_EMAIL=contact@votre-domaine.com
